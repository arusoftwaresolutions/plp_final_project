{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "env PYTHONPATH=/app/src streamlit run src/app.py --server.address 0.0.0.0 --server.port $PORT",
    "healthcheckPath": "/_stcore/health",
    "healthcheckTimeout": 60
  }
}
