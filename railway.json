{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "/app/start.sh",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 5
  },
  "environments": {
    "production": {
      "deploy": {
        "startCommand": "/app/start.sh",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 5
      }
    }
  }
}
